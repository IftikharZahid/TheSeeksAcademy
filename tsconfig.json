{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-native"
  },
  "exclude": [
    "node_modules",
    "TheSeeks-Dashboard"
  ]
}