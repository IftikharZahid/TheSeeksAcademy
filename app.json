{
  "expo": {
    "name": "The Seekers",
    "slug": "TheSeeks-Students",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0d1f3c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.TheSeeksAcademy.Students"
    },
    "android": {
      "package": "com.TheSeeksAcademy.Students",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#0d1f3c"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.jpg",
          "color": "#0d1f3c",
          "androidMode": "default",
          "androidCollapsedTitle": "The Seeks Academy"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The Seeks Academy needs access to your photos to set a profile picture."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow The Seeks Academy to access your photos.",
          "savePhotosPermission": "Allow The Seeks Academy to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "53ded874-125b-4e95-ab99-56fe0a753c37"
      }
    }
  }
}
